[python:Decrypt Save (Required)]
import uhashlib
import ubinascii
import rijndael

password = b'TKX73OHHK1qMonoICbpVT0hIDGe7SkW0'
salt     = b'71Ba2p0ULBGaE6oJ7TjCqwsls1jBKmRL'
derived_key = uhashlib.pbkdf2_sha1(password, salt, 10, 64)

key = derived_key[:32]
iv = derived_key[32:]

print("Rijndael Key:", ubinascii.hexlify(key))
print("Rijndael IV :", ubinascii.hexlify(iv))

ctx = rijndael.Rijndael(key, block_size = 32)
savedata = ctx.decrypt_cbc(savedata, iv)

print("Decrypted size:", len(savedata))


[python:Decompress Save (Required)]
import uzlib

print("Compressed size:", len(savedata))
savedata = uzlib.decompress(savedata, -15)

print("Unpack size:", len(savedata))


